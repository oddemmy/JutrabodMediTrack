# ─────────────────────────────────────────────────────────
# JutrabodMediTrack — Backend Environment Variables
# Copy this file to .env and fill in all values before running
# ─────────────────────────────────────────────────────────

# MongoDB connection string (from MongoDB Atlas or local)
MONGOURI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=your_jwt_secret_here

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Absolute URL of THIS backend (no trailing slash)
# Local:  http://localhost:8007
# Render: https://jutrabod-backend.onrender.com
BACKEND_URL=https://jutrabod-backend.onrender.com

# Absolute URL of the frontend (no trailing slash)
# Local:  http://localhost:5173
# Render: https://your-frontend.onrender.com
CLIENT_URL=https://your-frontend.onrender.com

# Brevo (Sendinblue) SMTP credentials for email sending
BREVO_USER=your_brevo_smtp_login@smtp-brevo.com
BREVO_PASS=your_brevo_smtp_key

# Optional: Cloudinary for image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
